        "Text": {
          "type": "cexolocstring",
          "value": {
            "6": "Benvenuto a Accademia, qui troverai tutte le informazioni riguardanti STORIA e COMPORTAMENTI da tenersi all'interno del Server."
          }
        }
      },
      {
        "__struct_id": 1,
        "Animation": {
